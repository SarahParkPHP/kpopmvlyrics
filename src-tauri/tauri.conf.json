{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "K-Pop MV Lyrics",
  "version": "0.1.0",
  "identifier": "com.kpopmvlyrics.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "K-Pop MV Lyrics",
        "width": 1240,
        "height": 860,
        "minWidth": 940,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; img-src 'self' asset: http: https: data: file:; media-src 'self' asset: file: blob: http: https:; connect-src ipc: http: https:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
