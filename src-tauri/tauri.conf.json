{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "K-Pop MV Lyrics",
  "version": "0.1.0",
  "identifier": "com.kpopmvlyrics.desktop",
  "build": {},
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "K-Pop MV Lyrics",
        "width": 1240,
        "height": 860,
        "minWidth": 940,
        "minHeight": 680
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPLOCALDATA/**"
        ]
      },
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost http: https: data: file:; connect-src ipc: http: https:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "ca-certificates",
          "gstreamer1.0-plugins-bad",
          "gstreamer1.0-plugins-base",
          "gstreamer1.0-plugins-good",
          "libgdk-pixbuf-2.0-0",
          "libgstreamer-plugins-base1.0-0",
          "libgstreamer1.0-0",
          "libgtk-4-1",
          "yt-dlp"
        ],
        "recommends": [
          "ffmpeg",
          "python3",
          "python3-pip",
          "python3-venv"
        ],
        "files": {
          "/usr/lib/kpopmvlyrics/run_qwen_asr.py": "../scripts/run_qwen_asr.py",
          "/usr/share/doc/kpopmvlyrics/ASR.md": "../packaging/linux/asr-dependencies.md",
          "/usr/share/doc/kpopmvlyrics/requirements-asr.txt": "../requirements-asr.txt"
        }
      },
      "rpm": {
        "depends": [
          "ca-certificates",
          "gstreamer1",
          "gstreamer1-plugins-bad-free",
          "gstreamer1-plugins-base",
          "gstreamer1-plugins-good",
          "gdk-pixbuf2",
          "gtk4",
          "yt-dlp"
        ],
        "recommends": [
          "ffmpeg",
          "python3",
          "python3-pip"
        ],
        "files": {
          "/usr/lib/kpopmvlyrics/run_qwen_asr.py": "../scripts/run_qwen_asr.py",
          "/usr/share/doc/kpopmvlyrics/ASR.md": "../packaging/linux/asr-dependencies.md",
          "/usr/share/doc/kpopmvlyrics/requirements-asr.txt": "../requirements-asr.txt"
        }
      },
      "appimage": {
        "bundleMediaFramework": false,
        "files": {
          "/usr/lib/kpopmvlyrics/run_qwen_asr.py": "../scripts/run_qwen_asr.py",
          "/usr/share/doc/kpopmvlyrics/ASR.md": "../packaging/linux/asr-dependencies.md",
          "/usr/share/doc/kpopmvlyrics/requirements-asr.txt": "../requirements-asr.txt"
        }
      }
    }
  }
}
